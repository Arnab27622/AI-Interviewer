# MongoDB Configuration
MONGO_URI=your_mongodb_uri_here

# Server Settings
FRONTEND_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# JDoodle Code Execution API (Free: 200 executions/day)
# Register at https://www.jdoodle.com and get credentials from API section
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here
